{
    "name": "herald",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check-types": "turbo run check-types",
        "prepare": "lefthook install"
    },
    "devDependencies": {
        "lefthook": "^2.1.3",
        "lint-staged": "^16.3.2",
        "prettier": "^3.7.4",
        "turbo": "^2.8.14",
        "typescript": "5.9.2"
    },
    "engines": {
        "node": ">=18"
    },
    "packageManager": "npm@11.7.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ]
}