{
    "name": "@herald/types",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "check-types": "tsc --noEmit"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./auth": {
            "types": "./dist/auth/index.d.ts",
            "import": "./dist/auth/index.js",
            "default": "./dist/auth/index.js"
        },
        "./responses": {
            "types": "./dist/responses/index.d.ts",
            "import": "./dist/responses/index.js",
            "default": "./dist/responses/index.js"
        },
        "./user": {
            "types": "./dist/user/index.d.ts",
            "import": "./dist/user/index.js",
            "default": "./dist/user/index.js"
        },
        "./auditLog": {
            "types": "./dist/auditLog/index.d.ts",
            "import": "./dist/auditLog/index.js",
            "default": "./dist/auditLog/index.js"
        },
        "./shared": {
            "types": "./dist/shared/index.d.ts",
            "import": "./dist/shared/index.js",
            "default": "./dist/shared/index.js"
        },
        "./dtos": {
            "types": "./dist/dtos/index.d.ts",
            "import": "./dist/dtos/index.js",
            "default": "./dist/dtos/index.js"
        },
        "./ports": {
            "types": "./dist/ports/index.d.ts",
            "import": "./dist/ports/index.js",
            "default": "./dist/ports/index.js"
        },
        "./package.json": "./package.json"
    },
    "devDependencies": {
        "@repo/typescript-config": "*",
        "typescript": "latest"
    }
}